---
import { Icon } from 'astro-icon/components'
import { getCollection } from 'astro:content'
import BlogCard from '../components/BlogCard.astro'
import { SITE_TITLE, SocialLinks, internalHref } from '../consts'
import BaseLayout from '../layouts/BaseLayout.astro'

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
)
---

<BaseLayout title={`Home | ${SITE_TITLE}`}>
	<div
		class="app-container flex flex-col gap-12 justify-center py-36 md:py-48 pt-44 md:pt-56 relative"
	>
		<div>
			<p class="block text-3xl opacity-70 mt-9 mb-4">I am</p>
			<h1 class="text-8xl font-bold leading-none">Markus Lewin</h1>
		</div>
		<p class="text-2xl max-w-2xl font-light leading-normal">
			A full-stack developer with over 8 years of experience building web apps.
			Based in Sweden.
		</p>
		<ul class="flex flex-wrap gap-8" role="list">
			{
				SocialLinks.map((link) => (
					<li>
						<a
							class="text-xl text-primary dark:text-primary-dark underline hover:underline underline-offset-4"
							href={link.url}
							rel="noreferrer"
						>
							{link.name}
						</a>
					</li>
				))
			}
		</ul>
	</div>

	<!-- Recent Posts Section -->
	<div class="app-container">
		<h2 class="section-title">Recent Posts</h2>
		<div class="posts-grid-container">
			{posts.slice(0, 4).map((post) => <BlogCard heading="h3" post={post} />)}
		</div>
		{
			posts.length > 4 ? (
				<a class="btn-secondary" href={internalHref('/blog')}>
					Read All
					<Icon size={20} name="mdi:arrow-right" />
				</a>
			) : null
		}
	</div>

	<!-- Contact Section -->
	<div class="app-container py-42 grid lg:grid-cols-2 gap-28 lg:gap-10">
		<div class="space-y-6">
			<h2 class="section-title">Frontend Mentor</h2>
			<p class="text-lg max-w-xl pb-4">
				I like honing my skills by solving front-end challenges provided by
				Frontend Mentor. Check out my solutions and comments below!
			</p>
			<a
				class="btn-secondary"
				href="https://www.frontendmentor.io/profile/markuslewin"
				rel="noreferrer"
			>
				Go to My Profile
				<Icon size={20} name="mdi:arrow-right" />
			</a>
		</div>
		<div class="space-y-6">
			<h2 class="section-title">Get in touch</h2>
			<p class="text-lg max-w-xl">
				Use the buttons below for my resume and email.
			</p>
			<div class="flex flex-wrap mt-auto space-x-4">
				<a class="btn-primary" href="mailto:lewinmarkus@gmail.com">
					Get in Touch
					<Icon height={20} name="mdi:email" />
				</a>
				<a class="btn-secondary" href={internalHref('/resume.pdf')}>
					Go to Resume
					<Icon size={20} name="mdi:arrow-right" />
				</a>
			</div>
		</div>
	</div>
</BaseLayout>
